generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PaymentStatus {
  Pending
  Done
}

enum TaskType {
  DeliverCylinder
  CollectEmptyCylinder
}

enum TaskStatus {
  Pending
  Completed
}

enum TaskPriority {
  Low
  Medium
  High
  Urgent
}

enum InventoryMovementType {
  StockIn
  StockOut
  EmptyIn
  EmptyOut
  Adjustment
}

model Admin {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  sessionVersion Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Customer {
  id                          String           @id @default(cuid())
  fullName                    String
  phoneNumber                 String           @unique
  fullAddress                 String
  area                        String
  notes                       String?
  totalCylindersReceived      Int              @default(0)
  totalEmptyCylindersReturned Int              @default(0)
  totalPendingPayment         Decimal          @default(0) @db.Decimal(12, 2)
  isActive                    Boolean          @default(true)
  aadharUrl                   String?
  panUrl                      String?
  foodLicenseUrl              String?
  gstProofUrl                 String?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  transactions                Transaction[]
  deliveryTasks               DeliveryTask[]
  paymentHistory              PaymentHistory[]

  @@index([area])
  @@index([fullName])
  @@index([phoneNumber])
}

model Transaction {
  id                     String           @id @default(cuid())
  customerId             String
  customer               Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  filledCylindersDelivered Int            @default(0)
  emptyCylindersReceived Int              @default(0)
  paymentAmount          Decimal          @default(0) @db.Decimal(12, 2)
  paymentStatus          PaymentStatus    @default(Pending)
  deliveryDate           DateTime         @default(now())
  notes                  String?
  revenueCountedAt       DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  paymentHistory         PaymentHistory[]
  revenueRecord          RevenueRecord?

  @@index([customerId, deliveryDate])
  @@index([paymentStatus, deliveryDate])
}

model DeliveryTask {
  id            String       @id @default(cuid())
  customerId    String
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  taskType      TaskType
  dueDate       DateTime
  status        TaskStatus   @default(Pending)
  priority      TaskPriority @default(Medium)
  reminderNotes String?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, dueDate])
  @@index([customerId])
}

model RevenueRecord {
  id            String      @id @default(cuid())
  transactionId String      @unique
  amount        Decimal     @db.Decimal(12, 2)
  recordedAt    DateTime    @default(now())
  note          String?
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([recordedAt])
}

model CylinderInventory {
  id             String                @id @default(cuid())
  movementType   InventoryMovementType
  filledQuantity Int                   @default(0)
  emptyQuantity  Int                   @default(0)
  reason         String
  createdAt      DateTime              @default(now())

  @@index([createdAt])
}

model PaymentHistory {
  id            String       @id @default(cuid())
  customerId    String
  transactionId String?
  amount        Decimal      @db.Decimal(12, 2)
  status        PaymentStatus
  paidAt        DateTime?
  note          String?
  createdAt     DateTime     @default(now())
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([status, paidAt])
}

model DailySummary {
  id                       String   @id @default(cuid())
  summaryDate              DateTime @unique
  revenue                  Decimal  @default(0) @db.Decimal(12, 2)
  paymentReceived          Decimal  @default(0) @db.Decimal(12, 2)
  filledCylindersDelivered Int      @default(0)
  emptyCylindersCollected  Int      @default(0)
  pendingPaymentsCount     Int      @default(0)
  pendingTasksCount        Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}
